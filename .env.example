# ── InterviewAI FREE Version ──────────────────────────────
# All services used here are 100% FREE

# Google Gemini API (FREE)
# Get your free key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1500 requests/day — more than enough!
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (make up any long string)
JWT_SECRET=make-up-any-long-random-string-here-123456

# Database
# SQLite for local dev (no setup needed)
DATABASE_URL=sqlite:///interviewai.db
# PostgreSQL for Render (Render gives FREE PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
